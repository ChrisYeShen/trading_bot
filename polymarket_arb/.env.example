# ── Polymarket ──────────────────────────────────────────────
# 独立钱包私钥（Polygon 网络，钱包内需持有 USDC）
POLY_PRIVATE_KEY=0xyour_private_key_here

# Polymarket CLOB host（主网固定值，无需修改）
POLY_HOST=https://clob.polymarket.com

# ── The Odds API（体育赔率）────────────────────────────────
# 免费注册 https://the-odds-api.com 获取
ODDS_API_KEY=your_odds_api_key_here

# ── 策略参数 ─────────────────────────────────────────────
# edge 触发阈值（默认 0.08 = 8%）
MIN_EDGE=0.08

# 每笔最大下单金额（USDC）
MAX_ORDER_SIZE=50

# 最多同时挂单数量
MAX_OPEN_ORDERS=10

# 主循环间隔（秒）
SCAN_INTERVAL=300

# dry_run 模式：true=只打印信号不下单，false=真实下单
DRY_RUN=true
