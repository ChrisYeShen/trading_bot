# ── Blockchain ──────────────────────────────────────────────────────────────
RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
CHAIN_ID=1
ORACLE_CONTRACT_ADDRESS=0xYourDeployedContractAddress
FEEDER_PRIVATE_KEY=0xYourFeederWalletPrivateKey

# ── Data source API keys (all optional – omit to skip that source) ──────────
VAST_AI_API_KEY=
RUNPOD_API_KEY=
LAMBDA_LABS_API_KEY=

# ── eBay hardware prices (optional) ─────────────────────────────────────────
EBAY_APP_ID=

# ── Oracle behaviour ─────────────────────────────────────────────────────────
UPDATE_INTERVAL_SECONDS=3600
MAX_PRICE_DEVIATION_PCT=30.0
GAS_LIMIT=500000
# MAX_FEE_PER_GAS_GWEI=50
