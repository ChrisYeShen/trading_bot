# ============================================================
# Hyperliquid Delta-Neutral Market Maker — Configuration
# 复制此文件为 .env 并填写你的参数
# ============================================================

# 你的 Ethereum 钱包私钥（不含 0x 前缀）
# 仅在本地使用，切勿泄露
PRIVATE_KEY=your_private_key_here

# 是否使用测试网（true=测试网, false=主网）
USE_TESTNET=false

# ────────────────────────────────────────
# BTC 做市参数
# ────────────────────────────────────────
BTC_SPREAD_BPS=5.0          # 报价价差（基点），5bps = 0.05%
BTC_ORDER_SIZE_USD=200.0    # 每侧挂单金额（USD）
MAX_POSITION_USD_BTC=5000.0 # 最大净持仓（USD 绝对值）

# ────────────────────────────────────────
# ETH 做市参数
# ────────────────────────────────────────
ETH_SPREAD_BPS=5.0
ETH_ORDER_SIZE_USD=200.0
MAX_POSITION_USD_ETH=3000.0

# ────────────────────────────────────────
# SOL 做市参数
# ────────────────────────────────────────
SOL_SPREAD_BPS=8.0          # SOL 流动性较差，用更大价差
SOL_ORDER_SIZE_USD=200.0
MAX_POSITION_USD_SOL=2000.0

# ────────────────────────────────────────
# 全局参数
# ────────────────────────────────────────
# 报价刷新间隔（秒），每 N 秒重新报价一次
QUOTE_REFRESH_INTERVAL=5.0

# 最大允许回撤（%），超过此值机器人自动停止并取消所有挂单
MAX_DRAWDOWN_PCT=10.0

# 组合日志频率（每 N 轮循环打印一次持仓概览）
PORTFOLIO_LOG_EVERY=12
